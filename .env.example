# Copy to .env (backend reads it via pydantic-settings; compose reads MEYES_JWT_SECRET / MEYES_SEED_DEMO)

# Security — REQUIRED in production
MEYES_JWT_SECRET=please-generate-a-long-random-secret

# Allowed CORS origins (comma-separated, or "*" for any). The UI is served
# same-origin behind the bundled proxy, so pin this to your host in production.
# MEYES_CORS_ALLOW_ORIGINS=https://m-eyes.local

# Database (default: sqlite:///./meyes.db; compose overrides with PostgreSQL)
# MEYES_DATABASE_URL=postgresql+psycopg://meyes:meyes@localhost:5432/meyes

# Engine endpoints (defaults suit local dev; compose overrides for containers)
# MEYES_BIND_OUTPUT_DIR=./out/bind
# MEYES_KEA_OUTPUT_DIR=./out/kea
# MEYES_RNDC_HOST=127.0.0.1
# MEYES_RNDC_PORT=953
# rndc control key — generated on first container boot into the shared bind volume.
# MEYES_RNDC_KEY_FILE=./out/bind/rndc.key
# MEYES_KEA_CA_URL=http://127.0.0.1:8001

# DNS defaults
# MEYES_DNS_DEFAULT_SOA_MNAME=ns1.m-eyes.local.
# MEYES_DNS_DEFAULT_SOA_RNAME=hostmaster.m-eyes.local.

# HTTPS / TLS
# Hostname clients use to reach M-Eyes — used as the CN/SAN of the auto-generated
# self-signed bootstrap certificate and prefilled when generating a CSR.
MEYES_HOSTNAME=m-eyes.local
# Where the active certificate, key and proxy snippets are published (compose only).
# MEYES_TLS_DIR=/shared/tls

# Seed demo data on container start (compose only). M-Eyes starts empty by
# default; set this to true only if you want sample networks/zones/scopes.
MEYES_SEED_DEMO=false

# Image version to run (compose only). Pin to a release (e.g. 1.3.0) for controlled
# upgrades; "latest" follows every release on `docker compose pull`.
# MEYES_VERSION=latest
