// M-Eyes generated BIND zone declarations - do not edit by hand
// config version: {{ config_version }}
{% macro zone_block(z, indent) %}
{{ indent }}zone "{{ z.name }}" {
{% if z.role == 'secondary' %}
{{ indent }}    type slave;
{{ indent }}    masters { {% for ip in z.primaries %}{{ ip }}; {% endfor %}};
{{ indent }}    file "{{ zone_dir }}/{{ z.filename }}";
{% if z.allow_query %}
{{ indent }}    allow-query {{ z.allow_query }};
{% endif %}
{% if z.allow_transfer %}
{{ indent }}    allow-transfer {{ z.allow_transfer }};
{% endif %}
{% if z.also_notify %}
{{ indent }}    also-notify {{ z.also_notify }};
{% endif %}
{% elif z.role == 'forward' %}
{{ indent }}    type forward;
{{ indent }}    forward {{ 'first' if z.forward_first else 'only' }};
{{ indent }}    forwarders { {% for ip in z.primaries %}{{ ip }}; {% endfor %}};
{% else %}
{{ indent }}    type master;
{{ indent }}    file "{{ zone_dir }}/{{ z.filename }}";
{% if z.dnssec %}
{{ indent }}    dnssec-policy default;
{{ indent }}    inline-signing yes;
{% endif %}
{% if z.allow_query %}
{{ indent }}    allow-query {{ z.allow_query }};
{% endif %}
{% if z.allow_transfer %}
{{ indent }}    allow-transfer {{ z.allow_transfer }};
{% endif %}
{% if z.allow_update %}
{{ indent }}    allow-update {{ z.allow_update }};
{% endif %}
{% if z.also_notify %}
{{ indent }}    also-notify {{ z.also_notify }};
{% endif %}
{% endif %}
{{ indent }}};
{% endmacro %}
{% if use_views %}
{% for view in views %}
view "{{ view.name }}" {
    match-clients { {{ view.match_clients }} };
{% for z in view.zones %}
{{ zone_block(z, '    ') -}}
{% endfor %}
{% if rpz %}
{{ zone_block(rpz, '    ') -}}
    response-policy { zone "{{ rpz.name }}"; } qname-wait-recurse no break-dnssec yes;
{% endif %}
};
{% endfor %}
{% else %}
{% for z in default_zones %}
{{ zone_block(z, '') -}}
{% endfor %}
{% if rpz %}
{{ zone_block(rpz, '') -}}
{% endif %}
{% endif %}
